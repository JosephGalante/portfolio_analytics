APP_NAME=Portfolio Analytics
APP_VERSION=0.1.0
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=["http://localhost:3000"]

DATABASE_URL=postgresql+asyncpg://portfolio:portfolio@postgres:5432/portfolio_analytics
REDIS_URL=redis://redis:6379/0

RUN_DB_MIGRATIONS_ON_START=true
RUN_EMBEDDED_WORKERS=false

GUEST_DEMO_MODE=false
GUEST_DEMO_RESET_ON_START=false
GUEST_DEMO_TOKEN_SECRET=local-demo-secret-change-me
GUEST_DEMO_SESSION_TTL_MINUTES=120
GUEST_DEMO_USER_EMAIL=guest-demo@portfolio-analytics.local
GUEST_DEMO_USER_NAME=Guest Demo

STYTCH_PROJECT_ID=
STYTCH_SECRET=
STYTCH_API_URL=https://test.stytch.com/v1

FINNHUB_API_KEY=
FINNHUB_API_URL=https://finnhub.io/api/v1
MARKET_DATA_POLL_INTERVAL_MS=15000
MARKET_DATA_REQUEST_TIMEOUT_SECONDS=10

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000
NEXT_PUBLIC_GUEST_DEMO_MODE=false
NEXT_PUBLIC_STYTCH_PUBLIC_TOKEN=
NEXT_PUBLIC_STYTCH_LOGIN_REDIRECT_URL=http://localhost:3000
NEXT_PUBLIC_STYTCH_PASSWORD_RESET_REDIRECT_URL=http://localhost:3000/authenticate
